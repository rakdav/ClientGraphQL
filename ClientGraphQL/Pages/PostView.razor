@page "/PostView"
@using ClientGraphQL.DataAccess
@using ClientGraphQL.DataAccess.Model;
@inject NavigationManager NavigationManager;
<h1>All posts</h1>
<a href="/CreatePost">Create post</a>
@if(AllPosts.Count==0){
    <p><em>Loading ...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Content</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in AllPosts)
            {
                <tr>
                    <td></td>
                    <td>@post.Title</td>
                    <td>@post.Author</td>
                    <td>@post.Content</td>
                </tr>
            }
        </tbody>
    </table>
}
@code {
    private List<Post> AllPosts = new List<Post>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            string query = "query{posts{title,author,content,createAt}}";
            string queryType = "posts";
            var result = await Query.
            ExecuteQueryReturnListAsync<Post>(queryType,query);
            AllPosts = result;
        }
        catch(Exception ex)
        {
            throw ex;
        }
    }
}
